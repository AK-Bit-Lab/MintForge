# =============================================================================
# StacksMinimint .gitignore
# =============================================================================
# This file defines which files and directories should be ignored by Git.
# Organized by category for easy maintenance.
# =============================================================================

# --- Dependencies ---
node_modules/
package-lock.json
!package-lock.json

# --- Environment Files ---
.env
.env.local
.env.*.local
.env.production

# --- Build Outputs ---
dist/
.cache/
build/
.next/
out/

# --- Deployment ---
deployments/

# --- Scripts (contains private keys and sensitive wallet data) ---
scripts/

# --- Settings (Network-specific, contain mnemonics/keys) ---
settings/Mainnet.toml
settings/Testnet.toml
settings/Devnet.toml
settings/Simnet.toml
settings/mainnet.toml

# --- Test and Debug Files ---
test-wallets.json
frontend/build_output*.txt
coverage/
*.lcov

# --- Backup Directories ---
scripts.backup-before-desktop-sync-*/
*.bak
*.backup

# --- IDE and Editor Files ---
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/

# --- Operating System Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# --- Temporary Files ---
*.tmp
*.temp
.temp/
tmp/
.tmp-vitest/

# --- Misc ---
*.pem
*.key
.vercel
scripts/test-hub-stake.cjs
