# MintForge Environment Configuration
# Copy this file to .env and update with your values

# Network Configuration
# Options: mainnet, testnet
VITE_STX_NETWORK=mainnet

# Contract Configuration
# Main NFT collection contract
VITE_CONTRACT_ADDRESS=SP5K2RHMSBH4PAP4PGX77MCVNK1ZEED07CWX9TJT
VITE_CONTRACT_NAME=minimint-core-v-i28

# Hub contract for staking and marketplace
VITE_HUB_CONTRACT_ADDRESS=SP5K2RHMSBH4PAP4PGX77MCVNK1ZEED07CWX9TJT
VITE_HUB_CONTRACT_NAME=minimint-hub-v-i28

# Mint Configuration
# Fee in micro-STX (e.g., 1000000 = 1 STX)
VITE_MINT_FEE=1000000

# API Configuration
# Hiro API endpoint (optional - uses default if not set)
# VITE_API_URL=https://api.hiro.so

# WebSocket Configuration (optional)
# VITE_WS_URL=wss://ws.hiro.so

# Feature Flags
# VITE_ENABLE_GALLERY=true
# VITE_ENABLE_STAKING=true
# VITE_ENABLE_MARKETPLACE=true

# Analytics (optional)
# VITE_ANALYTICS_ID=
# VITE_SENTRY_DSN=

# Development
# VITE_DEBUG_MODE=false

# Deployment Configuration (for deploy-hub.js and other deployment scripts)
# WARNING: NEVER commit your actual mnemonic or private keys to the repository!
# These should only exist in your local .env file
# DEPLOYMENT_MNEMONIC=your_mnemonic_seed_phrase_here
# DEPLOYMENT_PASSWORD=your_secure_password_here