# MintForge Frontend Configuration
# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# Stacks Network Mode
# Options: 'mainnet', 'testnet'
VITE_STX_NETWORK=mainnet

# Core NFT Contract (v-i28 deployment)
VITE_CONTRACT_ADDRESS=SP2KK5E7D3NFTSDMSJ7SFK99YY68194E3J2H6TT96
VITE_CONTRACT_NAME=minimint-core-v-i28

# Hub Contract — staking + marketplace (v-i28 deployment)
VITE_HUB_CONTRACT_ADDRESS=SP2KK5E7D3NFTSDMSJ7SFK99YY68194E3J2H6TT96
VITE_HUB_CONTRACT_NAME=minimint-hub-v-i28

# Reward Token Contract (v-i28 deployment)
VITE_TOKEN_CONTRACT_ADDRESS=SP2KK5E7D3NFTSDMSJ7SFK99YY68194E3J2H6TT96
VITE_TOKEN_CONTRACT_NAME=minimint-token-v-i28

# Mint fee override in micro-STX (0 = use SDK default)
VITE_MINT_FEE=0

# Optional: override the Hiro API base URL
# VITE_STACKS_API_URL=https://api.mainnet.hiro.so

# Feature flags
VITE_ENABLE_STAKING=true
VITE_ENABLE_MARKETPLACE=true
