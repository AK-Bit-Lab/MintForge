{
  "name": "mintforge",
  "version": "1.0.0",
  "description": "Modular NFT minting and rewards protocol on Stacks with Clarity contracts and a React frontend",
  "author": "MintForge Contributors",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "contracts:check": "clarinet check",
    "contracts:console": "clarinet console",
    "check": "npm run contracts:check && npm run test"
  },
  "keywords": [
    "stacks",
    "clarity",
    "smart-contracts",
    "nft",
    "web3",
    "bitcoin"
  ],
  "dependencies": {
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.3.1",
    "@stacks/wallet-sdk": "^7.2.0",
    "stacksminimint-sdk": "^0.2.1",
    "stacksminimint-protocol": "^0.1.3",
    "stacksminimint-utils": "^0.1.3",
    "stacksminimint-types": "^0.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@eslint/js": "^9.39.4",
    "@stacks/clarinet-sdk": "3.15.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vitest-environment-clarinet": "^3.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AK-Bit-Lab/MintForge.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/AK-Bit-Lab/MintForge/issues"
  },
  "homepage": "https://github.com/AK-Bit-Lab/MintForge#readme"
}
